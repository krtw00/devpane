# DevPane Configuration
# Copy to .env and modify as needed

# === Required ===
# PROJECT_ROOT=/path/to/target/repo

# === Application ===
# APP_NAME=DevPane               # Application name (default: DevPane)

# === Notification (at least one recommended) ===
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# === Schedule ===
# ACTIVE_HOURS=09-18          # Only run during these hours (24h format)

# === Agent Limits ===
# WORKER_TIMEOUT_MS=600000    # Worker timeout (default: 10min)
# PM_TIMEOUT_MS=300000        # PM timeout (default: 5min)
# WORKER_CONCURRENCY=1        # Parallel workers (default: 1)
# DEVPANE_MAX_RETRIES=2       # Max retry count (default: 2)

# === Loop Control ===
# IDLE_INTERVAL_SEC=60        # Poll interval when queue empty (default: 60)
# PM_RETRY_INTERVAL_SEC=30    # PM retry interval (default: 30)
# COOLDOWN_INTERVAL_SEC=300   # Cooldown after consecutive failures (default: 300)

# === Quality Gates ===
# DEVPANE_MAX_DIFF_SIZE=500   # Max diff lines before auto-fail (default: 500)
# PR_RISK_DIFF_THRESHOLD=300  # Diff threshold for PR risk assessment (default: 300)
# DEVPANE_MAX_OPEN_PRS=1      # Max simultaneous open PRs (default: 1)
# DEVPANE_MIN_DESCRIPTION_LENGTH=20  # Min task description length (default: 20)

# === Kaizen (Self-improvement) ===
# DEVPANE_KAIZEN_THRESHOLD=10         # Tasks between kaizen analysis (default: 10)
# DEVPANE_EFFECT_MEASURE_THRESHOLD=10 # Tasks before measuring improvement effect (default: 10)
# DEVPANE_MEMORY_CLEANUP_THRESHOLD=10 # Memory cleanup threshold (default: 10)

# === Git ===
# DEVPANE_BASE_BRANCH=main            # Base branch for PRs (default: main)
# DEVPANE_BRANCH_PREFIX=devpane       # Branch prefix for tasks (default: devpane)
# DEVPANE_PRUNE_INTERVAL_HOURS=6      # Interval for pruning merged branches (default: 6)
# DEVPANE_PR_MERGE_STRATEGY=--merge   # PR merge strategy (default: --merge)

# === Build/Test Commands ===
# DEVPANE_BUILD_CMD="pnpm build"
# DEVPANE_TEST_CMD="pnpm test"
# DEVPANE_LINT_CMD="pnpm --if-present run lint"
# DEVPANE_TEST_DIR=src/__tests__
# DEVPANE_TEST_FILE_PATTERN=*.test.ts
# DEVPANE_TEST_FRAMEWORK=vitest

# === Backup ===
# BACKUP_DIR=./.devpane-backups  # Backup directory (default: {PROJECT_ROOT}/.devpane-backups)
# BACKUP_KEEP_COUNT=7            # Number of backups to keep (default: 7)

# === Database ===
# DB_PATH=./devpane.db        # SQLite database path

# === LLM API ===
# LLM_BACKEND=openai-compatible   # default: openai-compatible
# LLM_API_KEY=sk-xxx              # API key
# LLM_BASE_URL=https://api.deepseek.com/v1  # API base URL
# LLM_MODEL=deepseek-chat         # Model name
# LLM_INPUT_PRICE=0.00000028      # $/token override for unknown models
# LLM_OUTPUT_PRICE=0.00000042     # $/token override for unknown models

# === Budget ===
# MONTHLY_COST_BUDGET_JPY=750  # Monthly budget in JPY (default: unlimited)
# DAILY_COST_BUDGET_JPY=30     # Daily budget in JPY (default: unlimited)
# USD_JPY_RATE=150              # USD/JPY exchange rate (default: 150)

# === Server ===
# API_PORT=3001               # Daemon API port (default: 3001)
# API_TOKEN=changeme          # Optional Bearer token for /api/* and /ws auth
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000  # Optional allowed origins (comma-separated)
